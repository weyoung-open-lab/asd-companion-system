# Copy this file to ".env" and fill in your real key.
# ".env" is git-ignored — NEVER commit your real key.
#
# The runnable demo (app/) uses YOUR OpenAI key to drive the LLM child agent.
# You pay only for your own usage; the key never leaves your machine.
OPENAI_API_KEY=your_key_here

# Optional: override the model used for the LLM child agent (default: gpt-4o)
# OPENAI_CHILD_MODEL=gpt-4o
