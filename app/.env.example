# Copy this file to "app/.env" (or repo-root ".env") and add your key.
# Both locations are git-ignored — NEVER commit your real key.
# The LLM child agent uses YOUR key; you pay only for your own usage.
OPENAI_API_KEY=your_key_here

# Optional: model for the LLM child agent (default gpt-4o)
# OPENAI_CHILD_MODEL=gpt-4o
